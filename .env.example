# =============================================================================
# Terrenosentrujillo.pe — Variables de entorno
# Copia este archivo como `.env.local` y completa los valores.
# En Vercel, configura estas mismas variables en Project Settings → Environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Sitio
# -----------------------------------------------------------------------------
# URL canónica del sitio en producción. Se usa en metadata, robots y sitemap.
NEXT_PUBLIC_SITE_URL=https://terrenosentrujillo.pe

# -----------------------------------------------------------------------------
# Sanity (CMS)
# https://www.sanity.io/manage → Project → Settings
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-03

# Token con permisos de LECTURA para ISR/preview (opcional en Fase 1).
SANITY_API_READ_TOKEN=

# Token con permisos de ESCRITURA (crea documentos Lead desde el form de
# contacto). Crearlo en manage.sanity.io → API → Tokens → Editor.
SANITY_API_WRITE_TOKEN=

# Secreto para webhook de Sanity que dispara revalidate en Next (Fase 5).
SANITY_REVALIDATE_SECRET=

# -----------------------------------------------------------------------------
# Resend — envío de emails del formulario de contacto (Fase 4)
# https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=
# Email desde el que se envían las notificaciones (debe ser un dominio verificado).
RESEND_FROM_EMAIL=notificaciones@terrenosentrujillo.pe
# Email al que llegan los leads.
CONTACT_TO_EMAIL=contacto@terrenosentrujillo.pe

# -----------------------------------------------------------------------------
# Analytics (opcionales — también pueden configurarse desde Sanity siteSettings)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
